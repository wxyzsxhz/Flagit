# --- App ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:8080

# --- MySQL ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=flag_nation
DB_USER=flag_app
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root

# --- JWT ---
# Access token: short-lived, stateless, sent in Authorization header
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token: opaque random string, hashed in DB, drives the 7-day "session"
JWT_REFRESH_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=fn_refresh

# --- Password reset ---
RESET_TOKEN_EXPIRES_MIN=30

# --- Email (SMTP via Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hninshweyiwint2022@gmail.com
# Use a Gmail App Password, not the account password
SMTP_PASSWORD=replace_with_gmail_app_password
MAIL_FROM="Flag Nation <hninshweyiwint2022@gmail.com>"

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=flag-nation-backend
KAFKA_NOTIFICATIONS_TOPIC=notifications
KAFKA_GROUP_ID=flag-nation-notifications-worker

# --- Karma ---
DAILY_LOGIN_KARMA=5
